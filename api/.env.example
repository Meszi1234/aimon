# Port the API listens on.
PORT=3000

# Postgres connection string used by the pg pool.
# Matches the local Docker Postgres defined in ../docker-compose.yml.
DATABASE_URL=postgres://aimtrainer:aimtrainer@localhost:5432/aimtrainer

# SSL for the DB connection. Leave UNSET for local Docker (plain TCP, no SSL).
# Set to `require` on Railway (Slice 6), where managed Postgres mandates TLS.
# PGSSL=require

# --- Slice 5/6 (declared here, not consumed yet) ---
# Allowed CORS origin (the web app's URL).
# CORS_ORIGIN=http://localhost:5173
